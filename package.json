{
  "name": "blockable-desktop",
  "version": "1.5.0",
  "description": "Blockable desktop game collection",
  "private": true,
  "main": "electron-main.cjs",
  "scripts": {
    "start": "electron .",
    "sync:web": "node scripts/sync-web.cjs",
    "mobile:sync": "npm run sync:web && cap sync",
    "mobile:ios": "npm run mobile:sync && cap open ios",
    "mobile:android": "npm run mobile:sync && cap open android",
    "verify": "node scripts/verify-build.cjs",
    "icon:windows": "node scripts/create-windows-icon.cjs",
    "build:windows:x64": "npm run icon:windows && electron-packager . Blockable --platform=win32 --arch=x64 --out=dist/windows --overwrite --icon=Assets/Blockable.ico --prune=true --ignore='^/(Blockable\\.app|Installer|dist|outputs|ios|android|resources|www|\\.github|\\.git)'",
    "build:windows:arm64": "npm run icon:windows && electron-packager . Blockable --platform=win32 --arch=arm64 --out=dist/windows --overwrite --icon=Assets/Blockable.ico --prune=true --ignore='^/(Blockable\\.app|Installer|dist|outputs|ios|android|resources|www|\\.github|\\.git)'",
    "build:windows": "npm run build:windows:x64 && npm run build:windows:arm64"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@electron/packager": "^20.0.3",
    "electron": "^43.1.1",
    "png-to-ico": "^3.0.2"
  }
}

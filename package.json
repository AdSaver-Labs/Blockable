{
  "name": "blockable-desktop",
  "version": "1.4.0",
  "description": "Blockable desktop game collection",
  "private": true,
  "main": "electron-main.cjs",
  "scripts": {
    "start": "electron .",
    "icon:windows": "node scripts/create-windows-icon.cjs",
    "build:windows:x64": "npm run icon:windows && electron-packager . Blockable --platform=win32 --arch=x64 --out=dist/windows --overwrite --icon=Assets/Blockable.ico --prune=true --ignore='^/(Blockable\\.app|Installer|dist|outputs|\\.git)'",
    "build:windows:arm64": "npm run icon:windows && electron-packager . Blockable --platform=win32 --arch=arm64 --out=dist/windows --overwrite --icon=Assets/Blockable.ico --prune=true --ignore='^/(Blockable\\.app|Installer|dist|outputs|\\.git)'",
    "build:windows": "npm run build:windows:x64 && npm run build:windows:arm64"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.3",
    "electron": "^43.1.1",
    "png-to-ico": "^3.0.2"
  }
}
